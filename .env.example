# Copy to .env and fill in your keys. Never commit secrets.

# Exchanges (read-only keys for data; only enable trade scope for live)
QT_BINANCE_API_KEY=
QT_BINANCE_API_SECRET=
QT_OKX_API_KEY=
QT_OKX_API_SECRET=
QT_OKX_PASSPHRASE=

# Data providers (free tiers usable for research)
QT_GLASSNODE_API_KEY=
QT_CRYPTOQUANT_API_KEY=
QT_COINGLASS_API_KEY=
QT_SANTIMENT_API_KEY=
QT_LUNARCRUSH_API_KEY=
QT_FRED_API_KEY=
QT_NEWSAPI_KEY=
QT_CRYPTOPANIC_TOKEN=

# Runtime flags
QT_ENV=research              # research | paper | live
QT_LIVE_TRADING_ENABLED=false
QT_LOG_LEVEL=INFO
QT_DATA_DIR=./data

# Alerts — Email (SMTP). Works with Gmail (app-password), Outlook, Aliyun DirectMail.
# Leave blank to disable email alerts.
QT_SMTP_HOST=                # e.g. smtp.gmail.com  or smtpdm.aliyun.com
QT_SMTP_PORT=465
QT_SMTP_USE_SSL=true
QT_SMTP_USER=                # e.g. you@example.com
QT_SMTP_PASSWORD=            # app password / SMTP password (NEVER your login password)
QT_SMTP_FROM=                # optional; defaults to QT_SMTP_USER
QT_SMTP_TO=                  # comma-separated recipients; defaults to QT_SMTP_USER

# Alerts — Telegram bot. Create one via @BotFather, message the bot once,
# then find your chat id at https://api.telegram.org/bot<TOKEN>/getUpdates
QT_TELEGRAM_BOT_TOKEN=
QT_TELEGRAM_CHAT_ID=

# Only deliver alerts at or above this severity: info | warning | critical
QT_ALERT_MIN_SEVERITY=info
